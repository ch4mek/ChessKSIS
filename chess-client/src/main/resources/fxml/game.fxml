<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.chess.client.gui.controller.GameController"
            style="-fx-background-color: #2c2c2c;">

    <!-- Top bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #333333; -fx-padding: 10;">
            <Label fx:id="turnLabel" text="Ваш ход" style="-fx-font-size: 16px; -fx-text-fill: #f0d9b5; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="gameStatusLabel" style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"/>
        </HBox>
    </top>

    <!-- Center: chess board -->
    <center>
        <VBox alignment="CENTER" spacing="5">
            <Label fx:id="opponentLabel" style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"/>
            <StackPane fx:id="boardContainer" prefWidth="480" prefHeight="480"/>
            <Label fx:id="playerLabel" style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"/>
        </VBox>
    </center>

    <!-- Right panel -->
    <right>
        <VBox spacing="10" style="-fx-padding: 15; -fx-pref-width: 220;">
            <Label text="Информация" style="-fx-font-size: 16px; -fx-text-fill: #f0d9b5; -fx-font-weight: bold;"/>
            <Label fx:id="colorLabel" text="Вы играете: Белыми" style="-fx-text-fill: #cccccc;"/>
            <Label fx:id="roomIdLabel" style="-fx-text-fill: #cccccc;"/>

            <Separator/>

            <Button fx:id="resignButton" text="Сдаться" onAction="#onResign" maxWidth="Infinity"
                    style="-fx-background-color: #8b4444; -fx-text-fill: white;"/>
            <Button fx:id="offerDrawButton" text="Предложить ничью" onAction="#onOfferDraw" maxWidth="Infinity"
                    style="-fx-background-color: #555555; -fx-text-fill: white;"/>
            <HBox spacing="5">
                <Button fx:id="acceptDrawBtn" text="Принять ничью" onAction="#onAcceptDraw" maxWidth="Infinity"
                        visible="false" style="-fx-background-color: #5a9e5a; -fx-text-fill: white;"/>
                <Button fx:id="declineDrawBtn" text="Отклонить" onAction="#onDeclineDraw" maxWidth="Infinity"
                        visible="false" style="-fx-background-color: #8b4444; -fx-text-fill: white;"/>
            </HBox>
            <Button fx:id="leaveRoomButton" text="Покинуть комнату" onAction="#onLeaveRoom" maxWidth="Infinity"
                    style="-fx-background-color: #555555; -fx-text-fill: white;"/>

            <Separator/>

            <Label text="История ходов" style="-fx-font-size: 14px; -fx-text-fill: #f0d9b5;"/>
            <ListView fx:id="moveHistoryList" VBox.vgrow="ALWAYS" prefHeight="200"
                      style="-fx-background-color: #3c3c3c; -fx-control-inner-background: #3c3c3c;"/>
        </VBox>
    </right>

    <bottom>
        <Label fx:id="statusLabel" style="-fx-text-fill: #ff6b6b; -fx-padding: 5; -fx-font-size: 12px;"/>
    </bottom>
</BorderPane>
