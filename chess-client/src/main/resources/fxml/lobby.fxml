<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.chess.client.gui.controller.LobbyController"
            style="-fx-background-color: #2c2c2c;">

    <!-- Top bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #1e1e1e; -fx-padding: 10 20;">
            <Label text="♚ ChessKSiS" style="-fx-font-size: 20px; -fx-text-fill: #f0d9b5; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel" style="-fx-text-fill: #cccccc; -fx-font-size: 14px;"/>
            <Label fx:id="ratingLabel" style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;"/>
            <Button text="Logout" onAction="#onLogout"
                    style="-fx-background-color: #555555; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- Center content -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <!-- Room actions -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Create Room" onAction="#onCreateRoom"
                        style="-fx-background-color: #5a9e5a; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 6 14;"/>
                <Button text="Refresh" onAction="#onRefreshRooms"
                        style="-fx-background-color: #555555; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 6 14;"/>
            </HBox>

            <!-- Room list -->
            <Label text="Available Rooms:" style="-fx-text-fill: #cccccc; -fx-font-size: 14px;"/>
            <TableView fx:id="roomsTable" prefHeight="400"
                       style="-fx-background-color: #3c3c3c; -fx-control-inner-background: #3c3c3c;">
                <columns>
                    <TableColumn fx:id="roomNameColumn" text="Room" prefWidth="200"/>
                    <TableColumn fx:id="playersColumn" text="Players" prefWidth="100"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                </columns>
            </TableView>

            <Button text="Join Selected Room" onAction="#onJoinRoom"
                    style="-fx-background-color: #4a90d9; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 6 14;"/>
        </VBox>
    </center>

    <!-- Bottom status bar -->
    <bottom>
        <HBox style="-fx-background-color: #1e1e1e; -fx-padding: 5 20;">
            <Label fx:id="statusLabel" style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;"/>
        </HBox>
    </bottom>
</BorderPane>
