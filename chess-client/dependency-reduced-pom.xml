<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <parent>
    <artifactId>chess-ksis</artifactId>
    <groupId>com.chess</groupId>
    <version>1.0-SNAPSHOT</version>
  </parent>
  <modelVersion>4.0.0</modelVersion>
  <artifactId>chess-client</artifactId>
  <name>Chess Client</name>
  <description>JavaFX chess client with TCP networking</description>
  <build>
    <plugins>
      <plugin>
        <groupId>org.openjfx</groupId>
        <artifactId>javafx-maven-plugin</artifactId>
        <version>0.0.8</version>
        <configuration>
          <mainClass>com.chess.client.ClientApp</mainClass>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>com.chess.client.Launcher</mainClass>
                </transformer>
              </transformers>
              <finalName>chess-client</finalName>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>com.akathist.maven.plugins.launch4j</groupId>
        <artifactId>launch4j-maven-plugin</artifactId>
        <version>2.5.1</version>
        <executions>
          <execution>
            <id>l4j-clui</id>
            <phase>package</phase>
            <goals>
              <goal>launch4j</goal>
            </goals>
            <configuration>
              <headerType>gui</headerType>
              <jar>target/chess-client.jar</jar>
              <outfile>target/ChessKSiS.exe</outfile>
              <errTitle>ChessKSiS</errTitle>
              <customProcName>true</customProcName>
              <classPath>
                <mainClass>com.chess.client.Launcher</mainClass>
              </classPath>
              <jre>
                <path>./jre</path>
                <minVersion>17</minVersion>
                <initialHeapSize>256</initialHeapSize>
                <maxHeapSize>512</maxHeapSize>
              </jre>
              <versionInfo>
                <fileVersion>1.0.0.0</fileVersion>
                <txtFileVersion>1.0.0</txtFileVersion>
                <fileDescription>ChessKSiS Online Chess</fileDescription>
                <copyright>ChessKSiS</copyright>
                <productVersion>1.0.0.0</productVersion>
                <txtProductVersion>1.0.0</txtProductVersion>
                <productName>ChessKSiS</productName>
                <internalName>ChessKSiS</internalName>
                <originalFilename>ChessKSiS.exe</originalFilename>
              </versionInfo>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
